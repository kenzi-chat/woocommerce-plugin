{
    "name": "kenzi-chat/woocommerce-plugin",
    "description": "Enable commerce data sync between WooCommerce and Kenzi.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://kenzi.chat/integrations/woocommerce",
    "authors": [
        {
            "name": "Kenzi",
            "homepage": "https://kenzi.chat"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.65",
        "php-stubs/woocommerce-stubs": "^10.6",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Kenzi\\Commerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kenzi\\Commerce\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "analyze": "phpstan analyse --memory-limit=512M",
        "test": "phpunit"
    }
}
